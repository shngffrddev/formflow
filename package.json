{
  "name": "formtrek",
  "version": "0.2.2",
  "description": "Multi-step forms with conditional branching, Zod validation, and partial persistence.",
  "keywords": [
    "react",
    "form",
    "multi-step",
    "wizard",
    "zod",
    "validation",
    "branching"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    }
  },
  "bin": {
    "formtrek": "cli/index.cjs"
  },
  "files": [
    "lib",
    "cli"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "build:cli": "npx esbuild src/cli/index.ts --bundle --platform=node --format=cjs --outfile=cli/index.cjs --banner:js=\"#!/usr/bin/env node\"",
    "build:all": "npm run build:lib && npm run build:cli",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.cli.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "zod": "^3.0.0"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.2",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
