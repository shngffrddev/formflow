{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationDir": "./lib",
    "emitDeclarationOnly": true,
    "rootDir": "./src/lib"
  },
  "include": ["src/lib"]
}
