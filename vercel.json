{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/docs/:path*",
      "has": [{ "type": "host", "value": "formtrek.dev" }],
      "destination": "https://docs.formtrek.dev/:path*",
      "permanent": false
    },
    {
      "source": "/docs",
      "has": [{ "type": "host", "value": "formtrek.dev" }],
      "destination": "https://docs.formtrek.dev/introduction",
      "permanent": false
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
